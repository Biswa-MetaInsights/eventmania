# EventMind — project-root environment file
# Copy to ".env" (same folder) and fill in. shadow_runner.py loads this and
# passes the values to every backend service. Never commit the real .env.

# ── Secrets ───────────────────────────────────────────────────────────────────
JWT_SECRET=dev_secret_key_64_bits_long_minimum_integrity
OPENAI_API_KEY=

# Ticketmaster Discovery API — free key from https://developer.ticketmaster.com
# Used by backend/scripts/sync_ticketmaster.py to populate the events catalogue.
TICKETMASTER_API_KEY=

# ── Local dev defaults (shadow_runner overrides DATABASE_URL to SQLite) ────────
# DATABASE_URL=postgresql://user:password@localhost:5432/event_db
